{
  "name": "tableau-chat-extension-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/localServer.ts",
    "build": "tsc",
    "build:lambda": "esbuild src/handlers/chatHandler.ts src/handlers/chatJobWorkerHandler.ts src/handlers/healthHandler.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist-lambda --sourcemap --minify",
    "lint": "eslint . && npm run format:check",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.json\" \"*.mjs\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1053.0",
    "@aws-sdk/client-dynamodb": "^3.850.0",
    "@aws-sdk/client-lambda": "^3.1063.0",
    "@aws-sdk/client-ssm": "^3.1053.0",
    "@aws-sdk/util-dynamodb": "^3.850.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tableau/mcp-server": "^2.2.4",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.0"
  }
}
